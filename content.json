nt-posts.pug include includes/partial 解决方案:执行如下命令 npm install --save hexo-renderer-jade hexo-generator-feed hexo-generator-sitemap hexo-browsersync hexo-generator-archive","categories":[],"tags":[]}],"categories":[],"tags":[]}